{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "requirements",
  "description": "Requirements summary",
  "type": "object",
  "properties": {
    "source": { "type": "string" },
    "summary": {
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "approved": { "type": "number" },
        "rejected": { "type": "number" }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["req_id", "title", "priority", "status"],
        "properties": {
          "req_id": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "status": { "type": "string", "enum": ["approved", "rejected", "proposed"] }
        }
      }
    }
  }
}
