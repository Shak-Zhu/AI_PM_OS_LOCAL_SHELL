{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "milestones",
  "description": "Project milestones",
  "type": "object",
  "properties": {
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["milestone_id", "name", "target_date", "status"],
        "properties": {
          "milestone_id": { "type": "string" },
          "name": { "type": "string" },
          "target_date": { "type": "string" },
          "status": { "type": "string", "enum": ["upcoming", "achieved", "missed", "at_risk"] },
          "owner": { "type": "string" }
        }
      }
    }
  }
}
