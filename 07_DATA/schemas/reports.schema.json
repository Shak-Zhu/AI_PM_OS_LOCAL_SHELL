{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "reports",
  "description": "Report registry",
  "type": "object",
  "properties": {
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["report_id", "title", "type", "generated_date"],
        "properties": {
          "report_id": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string", "enum": ["daily", "weekly", "monthly", "steering"] },
          "generated_date": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "published", "archived"] }
        }
      }
    }
  }
}
