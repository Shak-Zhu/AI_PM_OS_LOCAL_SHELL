{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "raid",
  "description": "RAID log entries",
  "type": "object",
  "properties": {
    "source": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "type", "description"],
        "properties": {
          "item_id": { "type": "string" },
          "type": { "type": "string", "enum": ["risk", "assumption", "issue", "dependency"] },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "mitigated", "closed"] }
        }
      }
    }
  }
}
