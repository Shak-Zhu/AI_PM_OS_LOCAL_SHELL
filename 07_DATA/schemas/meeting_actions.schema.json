{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "meeting_actions",
  "description": "Meeting action items (deduped)",
  "type": "object",
  "properties": {
    "meeting_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "description", "owner", "status"],
        "properties": {
          "action_id": { "type": "string" },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "completed", "cancelled"] },
          "due_date": { "type": "string" }
        }
      }
    }
  }
}
